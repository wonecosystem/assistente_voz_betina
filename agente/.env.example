# LiveKit
LIVEKIT_URL=wss://seu-projeto.livekit.cloud
LIVEKIT_API_KEY=sua_api_key
LIVEKIT_API_SECRET=seu_api_secret

# URL do Playground para testes
# https://agents-playground.livekit.io/

# Nome do agente
AGENT_NAME=Betina

# Nome do usuário que interage com o agente
USER_NAME=

# Provedor de LLM: google ou openai
LLM_PROVIDER=google

# Modelo LLM
# Google: gemini-2.5-flash-native-audio-latest, gemini-2.0-flash-exp-image-generation (suporta vídeo)
# OpenAI: gpt-4o-realtime-preview
LLM_MODEL=gemini-2.5-flash-native-audio-latest

# Google voices: Kore, Charon, Puck, Aoede, Fenrir
# OpenAI voices: alloy, ash, ballad, coral, echo, shimmer
AGENT_VOICE=Kore

LLM_TEMPERATURE=0.6

# Chaves de API (preencha a do provedor escolhido)
GOOGLE_API_KEY=
OPENAI_API_KEY=
